# scripts/vps/.env.example
# DLD Multi-Project Orchestrator environment config
# Copy to .env and fill in values: cp .env.example .env

# Paths
DB_PATH=/home/ubuntu/scripts/vps/orchestrator.db
PROJECTS_JSON=/home/ubuntu/scripts/vps/projects.json

# Orchestrator
POLL_INTERVAL=300

# Night Review
REVIEW_TIME=22:00
REVIEW_TZ=Europe/Moscow

# Gemini (Google AI)
GEMINI_API_KEY=

# Provider binaries
CLAUDE_PATH=/home/ubuntu/.claude/local/claude
CODEX_PATH=/usr/local/bin/codex
GEMINI_PATH=
PUEUE_PATH=/usr/local/bin/pueue

# Anthropic prompt caching (TECH-165)
# Enable 1-hour prompt cache TTL (snizhaet latency dlya council/bughunt sessions)
# Polezno na Max-podpiske — ne vliyaet na billing, uluchshaet response time.
ENABLE_PROMPT_CACHING_1H=1

# Callback audit log (TECH-171)
# Structured JSONL log — one record per verify_status_sync call.
# Default: scripts/vps/callback-audit.jsonl (same dir as callback.py).
# Override to move outside the repo (e.g. /var/log/dld-orchestrator/callback-audit.jsonl).
CALLBACK_AUDIT_LOG=/home/dld/projects/dld/scripts/vps/callback-audit.jsonl
