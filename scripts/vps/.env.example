# DLD VPS Autonomous Pipeline — Configuration
# Copy to .env and fill in your values

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789,987654321  # comma-separated Telegram user IDs

# ── Voice Transcription ──
# Options: openai, groq, local
WHISPER_PROVIDER=groq
# Required for openai/groq:
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ── Project Paths ──
PROJECT_DIR=/path/to/your/project
INBOX_DIR=${PROJECT_DIR}/ai/inbox
BACKLOG_FILE=${PROJECT_DIR}/ai/backlog.md
LOG_DIR=${PROJECT_DIR}/ai/diary/vps-logs

# ── Orchestrator ──
# How often to check inbox for new ideas (seconds)
INBOX_POLL_INTERVAL=300
# How often to check backlog for queued specs (seconds)
BACKLOG_POLL_INTERVAL=60
# Max specs to execute before stopping (safety limit)
MAX_SPECS_PER_RUN=10
# Max budget per spec (USD)
MAX_BUDGET_PER_SPEC=5.00

# ── Claude CLI flags ──
# Permission mode for autonomous execution
# WARNING: only use in isolated environments (VPS without sensitive data)
CLAUDE_PERMISSION_FLAGS="--dangerously-skip-permissions"
# Allowed tools (restrict for safety)
CLAUDE_ALLOWED_TOOLS="Read,Edit,Write,Glob,Grep,Bash(npm test *),Bash(npm run *),Bash(git *),Agent"
